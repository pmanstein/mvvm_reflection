{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run build_runner",
            "type": "shell",
            "command": "fvm dart run build_runner build --delete-conflicting-outputs",
        },
        {
            "label": "Watch build_runner",
            "type": "shell",
            "command": "fvm dart run build_runner watch --delete-conflicting-outputs",
        },
        {
            "label": "Run build_runner clean",
            "type": "shell",
            "command": "fvm dart run build_runner clean",
        },
        {
            "label": "Run custom_lint",
            "type": "shell",
            "command": "fvm dart run custom_lint",
        },
        {
            "label": "Watch custom_lint",
            "type": "shell",
            "command": "fvm dart run custom_lint --watch",
        },
        {
            "label": "Dart fix dry run",
            "type": "shell",
            "command": "fvm dart fix -n",
        },
        {
            "label": "Dart fix apply",
            "type": "shell",
            "command": "fvm dart fix --apply",
        },
        {
            "label": "melos bootstrap",
            "type": "shell",
            "command": "fvm exec melos bootstrap",
        },
        {
            "label": "melos generate",
            "type": "shell",
            "command": "fvm exec melos generate",
        },
        {
            "label": "melos test",
            "type": "shell",
            "command": "fvm exec melos test",
        },
        {
            "label": "melos lint",
            "type": "shell",
            "command": "fvm exec melos lint",
        },
        {
            "label": "melos generate:watch",
            "type": "shell",
            "command": "fvm exec melos generate:watch",
        },
        {
            "label": "melos patrol:test:all",
            "type": "shell",
            "command": "fvm exec melos patrol:test:all",
        },
        {
            "label": "melos patrol:test:select",
            "type": "shell",
            "command": "fvm exec melos patrol:test:select -- ${input:patrolTargetFile}",
        }
    ],
    "inputs": [
        {
            "id": "patrolTargetFile",
            "type": "promptString",
            "description": "Patrol test target relative to package, e.g. patrol_test/counter_page_test.dart"
        }
    ]
}